{
  "name": "miper",
  "version": "0.1.0",
  "description": "Autonomous Solana memecoin sniping bot with AI scoring",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "miper": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "snipe": "ts-node src/index.ts snipe",
    "snipe:pump": "ts-node src/index.ts snipe --source pump",
    "simulate": "SIMULATE=true ts-node src/index.ts snipe",
    "simulate:pump": "SIMULATE=true ts-node src/index.ts snipe --source pump",
    "monitor": "ts-node src/index.ts monitor",
    "monitor:pump": "ts-node src/index.ts monitor --source pump",
    "status": "ts-node src/index.ts status",
    "status:pump": "ts-node src/index.ts status --source pump",
    "review": "ts-node src/index.ts review",
    "review:pump": "ts-node src/index.ts review --source pump",
    "balance": "ts-node src/index.ts balance",
    "balance:pump": "ts-node src/index.ts balance --source pump",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@pump-fun/pump-sdk": "^1.35.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^11.0.0",
    "bs58": "^6.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "node-fetch": "^2.7.0",
    "openai": "^6.34.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
