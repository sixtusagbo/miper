# Solana RPC. Easiest: set just HELIUS_API_KEY (the bare key, no URL) and the
# Helius HTTP/WS endpoints are derived automatically. Explicit SOLANA_RPC_URL /
# SOLANA_WS_URL override the derivation (any provider). With neither set, the
# public mainnet endpoints are used — they 429 on almost every call, so only
# good for smoke tests.
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# Wallet (base58 encoded private key)
WALLET_PRIVATE_KEY=

# AI model. Provider is inferred from the prefix:
#   'gpt-' / 'o1' / 'o3' / 'chatgpt-' → OpenAI
#   'claude-'                         → Anthropic
# Leave blank to use the default (gpt-5-nano — cheapest model that supports
# structured JSON output, ~50x cheaper than Claude Sonnet 4 at our prompt
# size). Only the inferred provider's key is required; the other can stay blank.
AI_MODEL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Trading
BUY_AMOUNT_SOL=0.05
TAKE_PROFIT_1=2.0
TAKE_PROFIT_2=3.0
TAKE_PROFIT_3=5.0
SELL_PCT_TP1=40
SELL_PCT_TP2=30
SELL_PCT_TP3=30
STOP_LOSS=0.4
MAX_SLIPPAGE_BPS=300

# Exit strategy. 'tiered' (default) sells in three tranches at TP1/TP2/TP3.
# 'all-in' sells the entire bag at EXIT_AT_MULT and ignores TP1/TP2/TP3.
EXIT_MODE=tiered
EXIT_AT_MULT=2

# Auto-shutdown the snipe loop after N hours. 0 disables (run until SIGINT).
# Useful for unattended paper-trading sessions.
MAX_RUN_HOURS=0

# When true, the graceful shutdown handler sells every open/partial position
# at last-known price before exiting. Off by default. Recommended for live
# trading and bounded paper sessions where you want a clean session-end PnL.
CLOSE_ON_SHUTDOWN=false

# When true, the bot shuts itself down once the wallet balance is below
# BUY_AMOUNT_SOL (can't open a new position) AND no positions are open to
# manage. Winds a tapped-out run down instead of idling. Off by default.
CLOSE_WHEN_BELOW_MIN_BALANCE=false

# Force-exit any position that's been open longer than N minutes without
# hitting TP or SL. 0 disables (positions hold forever — historical default).
# R11b showed that with the cap full, positions that flatline between SL and
# TP camp forever and lock capital; a 10-min cap drains the corpse bag.
MAX_HOLD_MINUTES=0

# Circuit breaker: graceful shutdown after N consecutive failed buys (a
# systematic fault — bad encoding, dead RPC, drained wallet — fails every
# snipe). The counter resets on any successful buy. 0 disables.
MAX_CONSECUTIVE_BUY_FAILURES=5

# How long to cache pump.fun bonding-curve account-info reads, in ms. 0
# disables. R12 burnt 185k getAccountInfo calls in 22h reading the same
# curves on every 10s monitor tick; a 5s cache cuts that ~5-10x without
# affecting exits (marginal curve price barely shifts within seconds).
BONDING_CURVE_CACHE_MS=5000

# Priority fee on pump.fun buy/sell txs (micro-lamports per CU). The fee is
# set dynamically per tx from recent network fees and clamped to this range:
# PUMP_PRIORITY_MICROLAMPORTS is the floor, PUMP_PRIORITY_MAX_MICROLAMPORTS
# the ceiling. Raise the floor for a faster baseline; raise the max to stay
# competitive when the network is congested.
PUMP_PRIORITY_MICROLAMPORTS=100000
PUMP_PRIORITY_MAX_MICROLAMPORTS=5000000

# Momentum entry (pump source). Instead of sniping at launch, watch each new
# token's bonding-curve price for MOMENTUM_WINDOW_MIN minutes, sampling every
# MOMENTUM_SAMPLE_SEC seconds. A token must first climb into the
# [MOMENTUM_ENTRY_MULT_MIN, MOMENTUM_ENTRY_MULT_MAX] band — proof of real
# demand, not already parabolic. It is then bought not on the spike (a moving
# price reverts on slippage) but once it SETTLES: MOMENTUM_SETTLE_SAMPLES
# consecutive samples within MOMENTUM_SETTLE_TOLERANCE of each other (0.10 =
# the window's high within 10% of its low). MOMENTUM_WATCH_CAP bounds the
# watchlist. MOMENTUM_BUNDLE_THRESHOLD vetoes a token if that many distinct
# wallets bought in its launch slot (a bundled / manufactured pump); 0 disables.
MOMENTUM_WINDOW_MIN=5
# Keep MOMENTUM_SAMPLE_SEC >= ~25: a tighter interval, multiplied across the
# watchlist, blows past a typical RPC provider's per-second rate cap. The
# settle gate makes a slightly stale sample harmless (a plateau holds).
MOMENTUM_SAMPLE_SEC=25
MOMENTUM_ENTRY_MULT_MIN=1.4
MOMENTUM_ENTRY_MULT_MAX=2.5
MOMENTUM_SETTLE_SAMPLES=3
MOMENTUM_SETTLE_TOLERANCE=0.1
MOMENTUM_WATCH_CAP=40
MOMENTUM_BUNDLE_THRESHOLD=3
# Ignore a band-crossing within this many seconds of first seeing the token —
# too fast to catch before slippage, and usually a manufactured spike.
MOMENTUM_MIN_AGE_SEC=60

# Trending entry (trending source). Polls GeckoTerminal's Solana trending
# pools every TRENDING_POLL_SEC and buys graduated AMM tokens that clear a
# liquidity / market-cap / 24h-volume / pool-age filter — the user's manual
# DexScreener routine. Survivors are scored 0-100 by the LLM (name appeal +
# metrics) and bought via Jupiter when the score clears MIN_AI_SCORE.
TRENDING_POLL_SEC=45
TRENDING_MIN_LIQUIDITY_USD=10000
TRENDING_MAX_LIQUIDITY_USD=250000
TRENDING_MIN_MCAP_USD=22000
TRENDING_MIN_VOLUME_USD=50000
TRENDING_MIN_AGE_MIN=30
TRENDING_MAX_AGE_HOURS=24

# Copy-trading (copytrade source). Mirrors a curated set of proven Solana
# wallets: COPYTRADE_WALLETS is a comma-separated list of leader addresses,
# polled every COPYTRADE_POLL_SEC. COPYTRADE_LABELS is an optional, positionally
# matched comma-separated list of human names for those wallets — used in logs
# and DB attribution (per-leader landed-rate and PnL). A missing label falls
# back to a short address. A leader buy is copied only if the leader
# spent at least COPYTRADE_MIN_LEADER_SOL (dust isn't conviction). A leader
# sell mirrors as our full exit only when they sold at least
# COPYTRADE_SELL_EXIT_FRACTION of their holding (smaller trims are ignored, so
# a dust/test-sell can't dump our bag). The stop-loss and MAX_HOLD time-exit
# are independent floors.
#
# Copytrade needs NO AI key (the leader is the only signal). The intended live
# exit policy: leader-driven exits + STOP_LOSS + a MAX_HOLD_MINUTES floor. If
# you use EXIT_MODE=all-in, keep EXIT_AT_MULT high so take-profit doesn't
# pre-empt the leader's own exit; EXIT_MODE=tiered's TP ladder (2x/3x/5x) WILL
# pre-empt the leader, so prefer all-in (high mult) or accept the ladder.
COPYTRADE_WALLETS=
COPYTRADE_LABELS=
COPYTRADE_POLL_SEC=12
COPYTRADE_MIN_LEADER_SOL=0.5
# A leader sell >= this fraction of their holding triggers our full exit;
# smaller trims are ignored. 0.34 = mirror a >=1/3 sell. Note: this is per-tx,
# so it won't catch a leader scaling out in many tiny chunks.
COPYTRADE_SELL_EXIT_FRACTION=0.34

# Discovery scanner (discovery source). Watches every pump.fun launch for
# DISCOVERY_WINDOW_MIN minutes, extracting the features the wallet research
# measured (deployer history, funding wallet, holder growth, tx velocity,
# smart-wallet cluster buys, mcap/liquidity) and scoring them 0-100
# deterministically — no LLM. Thresholds and wallet lists come from the
# profile JSON produced by `npm run profile-wallets` (built-in defaults are
# used when the file is missing). Telegram alert at DISCOVERY_ALERT_SCORE;
# buy at DISCOVERY_BUY_SCORE only when DISCOVERY_AUTOBUY=true (off = the
# alert-only operating mode, and the kill switch for buying — alerts keep
# flowing). Position sizing/slippage/priority fees/stop-loss/time-exit and
# the consecutive-failure breaker are the same knobs every source uses.
DISCOVERY_PROFILE=./research/discovery-profile.json
DISCOVERY_WINDOW_MIN=5
# RPC budget: a watched token costs ~watchCap*(2+parsePerSample) calls per
# sample interval, plus a one-time launchParse burst and ~4 t0-intel calls.
# At the defaults that is ~3 req/s with a full watchlist — fine for a bounded
# peak-hour session, but ~3x a free Helius MONTHLY credit budget if run 24/7
# (see RUNNING.md "RPC budget"). Run it in bounded windows (MAX_RUN_HOURS) or
# upgrade RPC for continuous operation.
DISCOVERY_SAMPLE_SEC=25
DISCOVERY_WATCH_CAP=12
DISCOVERY_PARSE_PER_SAMPLE=2
# Launch-window parse depth: txs parsed in a token's FIRST sample, spent on the
# OLDEST signatures after the create — where the research showed the cluster's
# same-slot entries (the dominant smart-wallet signal) land. One-time per token.
DISCOVERY_LAUNCH_PARSE=8
DISCOVERY_ALERT_SCORE=55
DISCOVERY_BUY_SCORE=75
DISCOVERY_AUTOBUY=false
# Veto a launch when >= this many distinct wallets bought in its create slot
# (manufactured/bundled launch). 0 disables.
DISCOVERY_BUNDLE_THRESHOLD=3
# Intake throttle: skip launches whose creator co-deposited less than this,
# so watchlist slots go to profile-shaped launches. 0 disables.
DISCOVERY_MIN_DEV_BUY_SOL=0
# Extra smart wallets to track (comma-separated), merged with the profile's
# researched cluster.
DISCOVERY_SMART_WALLETS=

# Optional Telegram alerts (free; no-op if unset). Create a bot via @BotFather
# for the token, and get your chat id (e.g. message the bot then read
# https://api.telegram.org/bot<token>/getUpdates). Alerts fire on startup, a
# tripped circuit breaker, and a no-leader-activity heartbeat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Minutes of zero leader activity before a "still alive but quiet" heartbeat
# alert. 0 disables.
ALERT_HEARTBEAT_MINUTES=60

# Rotate the log file when it exceeds this many bytes. The previous file
# becomes pump.log.1, pump.log.1 -> pump.log.2, etc., up to LOG_MAX_FILES
# archives. 0 disables rotation (the historical behavior — log grows
# unbounded). 100 MB is a sane cap; R12's 24h log hit 54 MB.
LOG_MAX_BYTES=104857600
LOG_MAX_FILES=5

# Safety filters
MIN_LIQUIDITY_USD=5000
MAX_TOP_HOLDER_PCT=30
REQUIRE_MINT_REVOKED=true
REQUIRE_FREEZE_REVOKED=true

# AI
MIN_AI_SCORE=70

# Runtime
SIMULATE=true
SIMULATED_STARTING_SOL=1.0        # Virtual starting balance in paper mode
LOG_LEVEL=info                    # debug shows every external call; info is the default
LOG_FILE=                         # Optional: path to append full audit log. Defaults to ./pump.log when SOURCE=pump, unset otherwise.
MAX_OPEN_POSITIONS=10
DB_PATH=                          # Defaults to ./sniper.db (raydium) or ./pump.db (pump) when unset.

# Token source: 'raydium' (default) listens to Raydium AMM pool inits.
# 'pump' listens to pump.fun new-mint events. DB and log file default to
# pump-specific paths so runs don't mix trade history. Live pump trades go
# through the bonding curve directly while it's active, then fall back to
# Jupiter once the curve graduates and the token moves to PumpSwap.
SOURCE=raydium
