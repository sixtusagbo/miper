# Solana RPC (use Helius or QuickNode for better latency in production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Wallet (base58 encoded private key)
WALLET_PRIVATE_KEY=

# AI model. Provider is inferred from the prefix:
#   'gpt-' / 'o1' / 'o3' / 'chatgpt-' → OpenAI
#   'claude-'                         → Anthropic
# Leave blank to use the default (gpt-5-nano — cheapest model that supports
# structured JSON output, ~50x cheaper than Claude Sonnet 4 at our prompt
# size). Only the inferred provider's key is required; the other can stay blank.
AI_MODEL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Trading
BUY_AMOUNT_SOL=0.05
TAKE_PROFIT_1=2.0
TAKE_PROFIT_2=3.0
TAKE_PROFIT_3=5.0
SELL_PCT_TP1=40
SELL_PCT_TP2=30
SELL_PCT_TP3=30
STOP_LOSS=0.4
MAX_SLIPPAGE_BPS=300

# Exit strategy. 'tiered' (default) sells in three tranches at TP1/TP2/TP3.
# 'all-in' sells the entire bag at EXIT_AT_MULT and ignores TP1/TP2/TP3.
EXIT_MODE=tiered
EXIT_AT_MULT=2

# Safety filters
MIN_LIQUIDITY_USD=5000
MAX_TOP_HOLDER_PCT=30
REQUIRE_MINT_REVOKED=true
REQUIRE_FREEZE_REVOKED=true

# AI
MIN_AI_SCORE=70

# Runtime
SIMULATE=true
SIMULATED_STARTING_SOL=1.0        # Virtual starting balance in paper mode
LOG_LEVEL=info                    # debug shows every external call; info is the default
LOG_FILE=                         # Optional: path to append full audit log. Defaults to ./pump.log when SOURCE=pump, unset otherwise.
MAX_OPEN_POSITIONS=10
DB_PATH=                          # Defaults to ./sniper.db (raydium) or ./pump.db (pump) when unset.

# Token source: 'raydium' (default) listens to Raydium AMM pool inits.
# 'pump' listens to pump.fun new-mint events. DB and log file default to
# pump-specific paths so runs don't mix trade history. Phase 1 pump support
# is paper-only; live pump buys return an error.
SOURCE=raydium
